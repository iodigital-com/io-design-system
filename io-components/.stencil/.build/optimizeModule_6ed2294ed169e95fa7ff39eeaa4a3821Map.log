{"version":3,"names":["IoInput","constructor","hostRef","this","type","value","required","disabled","error","handleInput","ev","target","ioInput","emit","handleChange","ioChange","handleFocus","ioFocus","handleBlur","ioBlur","setFocus","options","input","_a","el","shadowRoot","querySelector","focus","render","label","name","placeholder","errorMessage","helperText","maxLength","autocomplete","inputId","Math","random","toString","slice","errorId","hasValue","h","Host","key","getInputStyles","class","htmlFor","id","undefined","onInput","onChange","onFocus","onBlur","role"],"sources":["src/components/io-input/io-input.tsx"],"sourcesContent":["import { Component, Prop, Event, EventEmitter, Method, Element, Host, h } from '@stencil/core';\nimport type { IoInputType } from './types';\n\n/**\n * io-input\n * =========\n * Text input with static label above the field.\n * Border expands from 1px → 5px on focus (io brand interaction).\n * The label never moves — it is always visible above the input.\n *\n * @example\n * <io-input label=\"Email address\" type=\"email\" name=\"email\" required />\n * <io-input label=\"Search\" type=\"search\" placeholder=\"Search...\" />\n */\n@Component({\n  tag: 'io-input',\n  shadow: { delegatesFocus: true },\n})\nexport class IoInput {\n  @Element() el!: HTMLElement;\n\n  /** Label text — required for accessibility */\n  @Prop() label!: string;\n\n  /** Input type */\n  @Prop() type: IoInputType = 'text';\n\n  /** Input name */\n  @Prop() name: string | undefined;\n\n  /** Current value */\n  @Prop({ mutable: true }) value = '';\n\n  /** Placeholder — shown when no value and label is resting */\n  @Prop() placeholder: string | undefined;\n\n  /** Marks the input as required */\n  @Prop() required = false;\n\n  /** Disables the input */\n  @Prop({ reflect: true }) disabled = false;\n\n  /** Puts the input in error state */\n  @Prop({ reflect: true }) error = false;\n\n  /** Error message shown below the input */\n  @Prop() errorMessage: string | undefined;\n\n  /** Helper text shown below the input (replaces error when no error) */\n  @Prop() helperText: string | undefined;\n\n  /** Max length */\n  @Prop() maxLength: number | undefined;\n\n  /** Autocomplete attribute */\n  @Prop() autocomplete: string | undefined;\n\n  @Event() ioInput!: EventEmitter<InputEvent>;\n  @Event() ioChange!: EventEmitter<string>;\n  @Event() ioFocus!: EventEmitter<FocusEvent>;\n  @Event() ioBlur!: EventEmitter<FocusEvent>;\n\n  @Method()\n  async setFocus(options?: FocusOptions): Promise<void> {\n    const input = this.el.shadowRoot?.querySelector<HTMLInputElement>('input');\n    input?.focus(options);\n  }\n\n  private handleInput = (ev: InputEvent) => {\n    this.value = (ev.target as HTMLInputElement).value;\n    this.ioInput.emit(ev);\n  };\n\n  private handleChange = (ev: Event) => {\n    this.ioChange.emit((ev.target as HTMLInputElement).value);\n  };\n\n  private handleFocus = (ev: FocusEvent) => {\n    this.ioFocus.emit(ev);\n  };\n\n  private handleBlur = (ev: FocusEvent) => {\n    this.ioBlur.emit(ev);\n  };\n\n  render() {\n    const { label, type, name, value, placeholder, required, disabled, error, errorMessage, helperText, maxLength, autocomplete } = this;\n    const inputId = `io-input-${name || Math.random().toString(36).slice(2)}`;\n    const errorId = `${inputId}-error`;\n    const hasValue = !!value;\n\n    return (\n      <Host>\n        <style>{getInputStyles()}</style>\n        <div class={`input-wrapper${error ? ' input-wrapper--error' : ''}${disabled ? ' input-wrapper--disabled' : ''}`}>\n          <label\n            htmlFor={inputId}\n            class={`input-label${hasValue ? ' input-label--float' : ''}`}\n          >\n            {label}\n            {required && <span class=\"input-required\" aria-hidden=\"true\"> *</span>}\n          </label>\n          <input\n            id={inputId}\n            class=\"input-field\"\n            type={type}\n            name={name}\n            value={value}\n            placeholder={placeholder}\n            required={required}\n            disabled={disabled}\n            maxLength={maxLength}\n            autocomplete={autocomplete}\n            aria-invalid={error ? 'true' : undefined}\n            aria-describedby={error && errorMessage ? errorId : undefined}\n            onInput={this.handleInput}\n            onChange={this.handleChange}\n            onFocus={this.handleFocus}\n            onBlur={this.handleBlur}\n          />\n        </div>\n        {error && errorMessage && (\n          <p id={errorId} class=\"input-error\" role=\"alert\">{errorMessage}</p>\n        )}\n        {!error && helperText && (\n          <p class=\"input-helper\">{helperText}</p>\n        )}\n      </Host>\n    );\n  }\n}\n\nfunction getInputStyles(): string {\n  return `\n    :host {\n      display: block;\n      font-family: var(--io-font-primary);\n    }\n\n    /* io brand: underline-only field — no box, no radius, no fill */\n    .input-wrapper {\n      border-bottom: var(--io-input-border-width) solid var(--io-text-primary);\n      transition: border-bottom-width var(--io-motion-fast);\n    }\n\n    .input-wrapper--focus {\n      border-bottom-width: var(--io-input-border-width-focus);\n    }\n\n    .input-wrapper--error {\n      border-bottom-color: var(--io-border-error);\n    }\n\n    .input-wrapper--disabled {\n      opacity: var(--io-state-disabled-opacity);\n      pointer-events: none;\n    }\n\n    /* Static label — always above the input, never animates */\n    .input-label {\n      display: block;\n      font-size: var(--io-label-font-size);\n      font-weight: var(--io-font-weight-medium);\n      color: var(--io-text-primary);\n    }\n\n    .input-required {\n      color: var(--io-color-error);\n    }\n\n    .input-field {\n      display: block;\n      width: 100%;\n      padding: var(--io-input-padding-y) 0;\n      font-size: var(--io-font-size-base);\n      font-family: var(--io-font-primary);\n      color: var(--io-text-primary);\n      background: transparent;\n      border: none;\n      outline: none;\n      min-height: var(--io-touch-target-min);\n    }\n\n    .input-field:focus-visible {\n      outline: none;\n    }\n\n    .input-error {\n      margin: var(--io-space-1) 0 0;\n      font-size: var(--io-font-size-xs);\n      color: var(--io-color-error);\n    }\n\n    .input-helper {\n      margin: var(--io-space-1) 0 0;\n      font-size: var(--io-font-size-xs);\n      color: var(--io-text-secondary);\n    }\n\n    @media (prefers-reduced-motion: reduce) {\n      .input-wrapper { transition: none; }\n    }\n  `;\n}\n"],"mappings":"sEAkBaA,EAAO,MAJpB,WAAAC,CAAAC,G,8IAWUC,KAAAC,KAAoB,OAMHD,KAAAE,MAAQ,GAMzBF,KAAAG,SAAW,MAGMH,KAAAI,SAAW,MAGXJ,KAAAK,MAAQ,MAyBzBL,KAAAM,YAAeC,IACrBP,KAAKE,MAASK,EAAGC,OAA4BN,MAC7CF,KAAKS,QAAQC,KAAKH,EAAG,EAGfP,KAAAW,aAAgBJ,IACtBP,KAAKY,SAASF,KAAMH,EAAGC,OAA4BN,MAAM,EAGnDF,KAAAa,YAAeN,IACrBP,KAAKc,QAAQJ,KAAKH,EAAG,EAGfP,KAAAe,WAAcR,IACpBP,KAAKgB,OAAON,KAAKH,EAAG,C,CAnBtB,cAAMU,CAASC,G,MACb,MAAMC,GAAQC,EAAApB,KAAKqB,GAAGC,cAAU,MAAAF,SAAA,SAAAA,EAAEG,cAAgC,SAClEJ,IAAK,MAALA,SAAK,SAALA,EAAOK,MAAMN,E,CAoBf,MAAAO,GACE,MAAMC,MAAEA,EAAKzB,KAAEA,EAAI0B,KAAEA,EAAIzB,MAAEA,EAAK0B,YAAEA,EAAWzB,SAAEA,EAAQC,SAAEA,EAAQC,MAAEA,EAAKwB,aAAEA,EAAYC,WAAEA,EAAUC,UAAEA,EAASC,aAAEA,GAAiBhC,KAChI,MAAMiC,EAAU,YAAYN,GAAQO,KAAKC,SAASC,SAAS,IAAIC,MAAM,KACrE,MAAMC,EAAU,GAAGL,UACnB,MAAMM,IAAarC,EAEnB,OACEsC,EAACC,EAAI,CAAAC,IAAA,4CACHF,EAAA,SAAAE,IAAA,4CAAQC,KACRH,EAAA,OAAAE,IAAA,2CAAKE,MAAO,gBAAgBvC,EAAQ,wBAA0B,KAAKD,EAAW,2BAA6B,MACzGoC,EAAA,SAAAE,IAAA,2CACEG,QAASZ,EACTW,MAAO,cAAcL,EAAW,sBAAwB,MAEvDb,EACAvB,GAAYqC,EAAA,QAAAE,IAAA,2CAAME,MAAM,iBAAgB,cAAa,QAAM,OAE9DJ,EAAA,SAAAE,IAAA,2CACEI,GAAIb,EACJW,MAAM,cACN3C,KAAMA,EACN0B,KAAMA,EACNzB,MAAOA,EACP0B,YAAaA,EACbzB,SAAUA,EACVC,SAAUA,EACV2B,UAAWA,EACXC,aAAcA,EAAY,eACZ3B,EAAQ,OAAS0C,UAAS,mBACtB1C,GAASwB,EAAeS,EAAUS,UACpDC,QAAShD,KAAKM,YACd2C,SAAUjD,KAAKW,aACfuC,QAASlD,KAAKa,YACdsC,OAAQnD,KAAKe,cAGhBV,GAASwB,GACRW,EAAA,KAAAE,IAAA,2CAAGI,GAAIR,EAASM,MAAM,cAAcQ,KAAK,SAASvB,IAElDxB,GAASyB,GACTU,EAAA,KAAAE,IAAA,2CAAGE,MAAM,gBAAgBd,G,mEAOnC,SAASa,IACP,MAAO,mwDAsET,Q","ignoreList":[]}