{
  "name": "@io-digital/components",
  "version": "1.0.0",
  "description": "io Digital Design System — Framework-agnostic Web Components built with Stencil.js",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "loader/",
    "dist-custom-elements/"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js"
    },
    "./loader": {
      "import": "./loader/index.js"
    },
    "./dist-custom-elements": {
      "import": "./dist-custom-elements/index.js"
    },
    "./styles": {
      "import": "./dist/styles/index.js"
    }
  },
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "browser": "dist/io-components/io-components.esm.js",
  "scripts": {
    "build": "stencil build",
    "build.watch": "stencil build --watch",
    "dev:stencil": "stencil build --watch --serve",
    "dev": "concurrently -n \"stencil,storefront\" -c \"blue,green\" \"npm run dev:stencil\" \"npm --prefix ../io-storefront run dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "generate": "stencil generate"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@stencil/core": "~4.43.3",
    "lucide": "^0.577.0"
  },
  "devDependencies": {
    "@stencil/angular-output-target": "^0.9.0",
    "@stencil/react-output-target": "^0.5.3",
    "@stencil/vue-output-target": "^0.8.8",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
